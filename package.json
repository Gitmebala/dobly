{
  "name": "dobly",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "dev:clean": "node ./scripts/clean-next.mjs && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "dev:turbo": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "clean": "node ./scripts/clean-next.mjs",
    "rebuild": "node ./scripts/clean-next.mjs && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck:billing": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -p tsconfig.billing.json --pretty false",
    "test": "node --test --experimental-strip-types src/lib/dobly-inference.test.mts src/lib/dobly-operating-system.test.mts src/lib/office/coordination-logic.test.mts src/lib/outcome-contracts-core.test.mts src/lib/runtime/execution-strategy.test.mts src/lib/runtime/artifact-quality.test.mts src/lib/billing/economy-core.test.mts src/lib/security/network-core.test.mts",
    "test:dobly-runtime": "node --test --experimental-strip-types src/lib/dobly-inference.test.mts src/lib/dobly-operating-system.test.mts src/lib/office/coordination-logic.test.mts src/lib/outcome-contracts-core.test.mts src/lib/runtime/execution-strategy.test.mts src/lib/runtime/artifact-quality.test.mts",
    "test:billing": "node --test --experimental-strip-types src/lib/billing/economy-core.test.mts",
    "test:security": "node --test --experimental-strip-types src/lib/security/network-core.test.mts",
    "validate:env": "node ./scripts/validate-env.mjs",
    "verify:schema": "node ./scripts/verify-schema.mjs",
    "ci": "npm run typecheck && npm run test && npm run build",
    "smoke": "node ./scripts/smoke-test.mjs",
    "office:worker": "node ./scripts/office-worker.mjs",
    "runtime:worker": "node ./scripts/runtime-worker.mjs",
    "service:worker": "node ./scripts/service-runner.mjs",
    "mobile:assets": "node ./scripts/generate-mobile-assets.mjs",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:still": "remotion still remotion/index.ts DoblyMascotLoop out/dobly-mascot-loop.png",
    "remotion:render": "remotion render remotion/index.ts DoblyMascotLoop out/dobly-mascot-loop.mp4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^5.1.0",
    "@next/swc-wasm-nodejs": "^15.5.19",
    "@pinecone-database/pinecone": "^7.2.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@stripe/stripe-js": "^4.9.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elevenlabs": "^1.59.0",
    "framer-motion": "^11.13.1",
    "gsap": "^3.14.2",
    "intasend-node": "^1.1.2",
    "lenis": "^1.3.20",
    "lucide-react": "^0.468.0",
    "nanoid": "^3.3.11",
    "next": "^15.5.19",
    "postcss": "^8.5.15",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "shadcn": "^4.2.0",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.6.1",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.459",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.19",
    "remotion": "^4.0.484",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2"
  }
}
